{
  "name": "relay-schoolbox-calendar-sync",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "local": "npm run dev",
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "postbuild": "node scripts/prepare-standalone.mjs",
    "start": "node scripts/production-runner.mjs",
    "scheduler": "node scripts/scheduler.mjs",
    "setup:env": "node scripts/setup-environment.mjs",
    "setup:dev-env": "node scripts/setup-environment.mjs --development",
    "auth:bootstrap": "node scripts/bootstrap-admin.mjs",
    "auth:reset-password": "node scripts/reset-admin-password.mjs",
    "test": "node --import tsx --test tests/*.test.mjs && npm run build",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "jose": "^6.1.3",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.14"
  },
  "type": "module"
}
