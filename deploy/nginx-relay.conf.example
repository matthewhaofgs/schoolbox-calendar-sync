# Place the limit_req_zone directive inside nginx's http {} block.
# This example assumes nginx runs on the Relay host. Keep TCP 3000 blocked from
# the general LAN; permit it only from this proxy (or the proxy's private IP).
# Apply the same IT-subnet/VPN restriction to inbound HTTPS at the host firewall.
limit_req_zone $binary_remote_addr zone=relay_login:10m rate=5r/m;

server {
    listen 80;
    listen [::]:80;
    server_name relay.school.edu.au;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name relay.school.edu.au;

    ssl_certificate     /etc/nginx/tls/relay.fullchain.pem;
    ssl_certificate_key /etc/nginx/tls/relay.key;
    ssl_protocols TLSv1.2 TLSv1.3;

    client_max_body_size 2m;
    add_header Strict-Transport-Security "max-age=31536000" always;

    location = /api/auth/login {
        limit_req zone=relay_login burst=3 nodelay;
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/proxy_params;
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-Proto https;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 2h;
        proxy_send_timeout 2h;
        proxy_buffering off;
    }
}
