# Generate a complete production file interactively with: npm run setup:env
NODE_ENV=production
RELAY_HOST=0.0.0.0
PORT=3000
APP_ORIGIN=https://relay.school.edu.au
DATABASE_PATH=data/relay.sqlite

# Long random secrets. Never commit real values.
CONFIG_ENCRYPTION_KEY=
SESSION_SECRET=
SCHEDULER_TOKEN=

# Optional environment overrides. Normally configure these from IT access in Relay.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_DOMAIN=
